# ==============================================================================
# Next.js Configuration Template
# Copy this file to '.env' and fill in your actual values.
# ==============================================================================

# Supabase project URL (local dev default shown)
NEXT_PUBLIC_SUPABASE_PROJECT_URL=http://localhost:54321

# Supabase publishable (anon) key — safe to expose to the client
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key

# Base URL of the app (local dev default shown)
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Supabase secret (service role) key — server-only, keep private
SUPABASE_SECRET_KEY=your-secret-service-role-key
