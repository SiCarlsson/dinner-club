# ==========================================
# SECRETS & ENVIRONMENT FILES
# ==========================================
.env
.env.*
!.env.example
*.tfvars
*.tfvars.json

# ==========================================
# NEXT.JS & NODE (Inside the web/ directory)
# ==========================================
web/node_modules/
web/.next/
web/out/
web/build/
web/next-env.d.ts
web/.vercel/

# Yarn/PnP specific (if used inside web)
web/.pnp
web/.pnp.*
web/.yarn/*
!web/.yarn/patches
!web/.yarn/plugins
!web/.yarn/releases
!web/.yarn/versions

# Playwright (inside the web/ directory)
web/test-results/
web/playwright-report/
web/blob-report/
web/playwright/.cache/
web/tests/e2e/.auth/

# ==========================================
# TERRAFORM (Inside the terraform/ directory)
# ==========================================
.terraform/
*.tfstate
*.tfstate.*
.terraform.lock.hcl

# ==========================================
# DEBUG, LOGS & TESTING
# ==========================================
web/coverage/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
.pnpm-store/

# ==========================================
# MISC / SYSTEM FILES
# ==========================================
.DS_Store
Thumbs.db
*.pem
*.tsbuildinfo

# Supabase
.branches
.temp
supabase/snippets/