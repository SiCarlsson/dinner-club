# ==========================================
# 1. SECRETS & ENVIRONMENT FILES
# ==========================================
.env
.env.local
.env.*
*.tfvars
*.tfvars.json

# ==========================================
# 2. NEXT.JS & NODE (Inside the web/ directory)
# ==========================================
web/node_modules/
web/.next/
web/out/
web/build/
web/next-env.d.ts
web/.vercel/

# Yarn/PnP specific (if used inside web)
web/.pnp
web/.pnp.*
web/.yarn/*
!web/.yarn/patches
!web/.yarn/plugins
!web/.yarn/releases
!web/.yarn/versions

# ==========================================
# 3. TERRAFORM (Inside the terraform/ directory)
# ==========================================
.terraform/
*.tfstate
*.tfstate.*
.terraform.lock.hcl

# ==========================================
# 4. DEBUG, LOGS & TESTING
# ==========================================
web/coverage/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
.pnpm-store/

# ==========================================
# 5. MISC / SYSTEM FILES
# ==========================================
.DS_Store
Thumbs.db
*.pem
*.tsbuildinfo